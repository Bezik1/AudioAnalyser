#!/bin/bash

echo "Starting pre-commit checks..."

if ! command -v cmake &> /dev/null || ! command -v ninja &> /dev/null; then
    echo "Error: cmake or ninja not found."
    exit 1
fi

if ! command -v brew &> /dev/null; then
    echo "Error: Homebrew not found (required for dependencies)."
    exit 1
fi

if ! brew list google-benchmark &> /dev/null; then
    echo "google-benchmark not found. Installing..."
    brew install google-benchmark
fi

if ! brew list qt6 &> /dev/null; then
    echo "qt6 not found. Installing..."
    brew install qt6
fi

QT_PREFIX=$(brew --prefix qt6)

echo "Configuring project..."
cmake -S . -B build \
    -G Ninja \
    -DCMAKE_PREFIX_PATH="${QT_PREFIX}" \
    -DCMAKE_BUILD_TYPE=Release

if [ $? -ne 0 ]; then
    echo "Configuration failed. Retrying with a clean build directory..."
    rm -rf build
    cmake -S . -B build \
        -G Ninja \
        -DCMAKE_PREFIX_PATH="${QT_PREFIX}" \
        -DCMAKE_BUILD_TYPE=Release

    if [ $? -ne 0 ]; then
        echo "Configuration failed again."
        exit 1
    fi
fi

echo "Building tests..."
cmake --build build --target tests --parallel $(sysctl -n hw.ncpu)

if [ $? -ne 0 ]; then
    echo "Build failed."
    exit 1
fi

echo "Running tests..."
./build/tests

if [ $? -ne 0 ]; then
    echo "Tests failed."
    exit 1
fi

echo "Building benchmarks..."
cmake --build build --target benchmarks --parallel $(sysctl -n hw.ncpu)

echo "Running benchmarks..."
BENCH_OUT=$(./build/benchmarks)
echo "$BENCH_OUT"

echo "$BENCH_OUT" | awk '
/RMS/ {
    if ($2 + 0 > 10) {
        print "Complexity RMS check failed (exceeded 10% threshold):"
        print $0
        exit 1
    }
}'

if [ $? -ne 0 ]; then
    exit 1
fi

echo "Pre-commit checks passed."
exit 0